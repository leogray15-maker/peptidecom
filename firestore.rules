rules_version = '2';

// Firestore security rules for The Arcane Lab.
//
// Live chat is the only collection clients touch directly. All TSW/recovery
// data — users/{uid} profiles + dailyLogs/photos/triggerLogs/milestones
// subcollections, recoveryStories, sharedPhotos, funnelEvents — is read and
// written exclusively through the server (Admin SDK bypasses these rules),
// so no client rules are declared for it and it stays deny-by-default.
//
// Chat access is gated on the `member` custom claim, which the server sets
// from the user's Stripe subscription status (see src/lib/auth.ts ->
// syncMembershipClaim).
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember() {
      return request.auth != null && request.auth.token.member == true;
    }

    match /channels/{channelId}/messages/{messageId} {
      // Any paid-up member can read the chat.
      allow read: if isMember();

      // Members can post messages as themselves; basic shape/length validation.
      allow create: if isMember()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;

      // Messages are immutable from the client (moderation happens server-side/admin).
      allow update, delete: if false;
    }
  }
}
