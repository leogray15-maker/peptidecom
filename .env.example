# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (Vercel Postgres, Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/peptidecom?schema=public"

# ─── Firebase (Authentication + Firestore chat) ──────────────────────────────
# Client config — from Firebase console → Project settings → Your apps (Web app).
# These are public (safe to expose in the browser).
NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="1234567890"
NEXT_PUBLIC_FIREBASE_APP_ID="1:1234567890:web:abcdef"

# Admin SDK (server) — from a service account JSON key (Project settings →
# Service accounts → Generate new private key). Keep these SECRET.
#
# EASIEST: paste the ENTIRE service-account JSON into a single variable:
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}'
#
# OR provide the three fields separately (leave FIREBASE_SERVICE_ACCOUNT unset):
# FIREBASE_PROJECT_ID="your-project"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From `stripe listen` locally, or the dashboard webhook endpoint in prod
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs for your subscription products (create these in the Stripe dashboard)
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_ANNUAL="price_..."

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="The Arcane Lab"
# Comma-separated emails that are always ADMIN with full access (bypass paywall).
ADMIN_EMAILS="leogray15@gmail.com"
