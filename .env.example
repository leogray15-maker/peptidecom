# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (Vercel Postgres, Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/peptidecom?schema=public"

# ─── Auth.js (NextAuth) ──────────────────────────────────────────────────────
# Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# Full canonical URL of the site (used for callbacks). In prod set to https://yourdomain.com
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From `stripe listen` locally, or the dashboard webhook endpoint in prod
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs for your subscription products (create these in the Stripe dashboard)
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_ANNUAL="price_..."

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="The Grey Lab"
